    <HBox fx:id="dashCard" spacing="10">
        <VBox>
            <padding>
                <Insets bottom="5" left="15" right="10" top="5" />
            </padding>
            <Label fx:id="newMembers" styleClass="dash-number-label" />
            <Label styleClass="details-small-label" text="New Memberships this week" />
        </VBox>
    </HBox>
    <HBox spacing="10" stylesheets="@DarkTheme.css">
        <VBox fx:id="dashCard" prefWidth="225">
            <padding>
                <Insets bottom="5" left="15" right="15" top="5" />
            </padding>
            <Label fx:id="annualMembers" styleClass="dash-number-label" />
            <Label styleClass="details-small-label" text="Annual Memberships" />
        </VBox>
        <VBox fx:id="dashCard" prefWidth="225">
            <padding>
                <Insets bottom="5" left="15" right="15" top="5" />
            </padding>
            <Label fx:id="monthlyMembers" styleClass="dash-number-label" />
            <Label styleClass="details-small-label" text="Monthly Memberships" />
        </VBox>
    </HBox>


</VBox>
